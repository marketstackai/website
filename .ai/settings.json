{
  "mcpServers": {
    "ghl": {
      "command": "node",
      "args": ["${GHL_MCP_SERVER_PATH}"],
      "env": {
        "GHL_API_KEY": "${GHL_API_KEY}",
        "GHL_LOCATION_ID": "${GHL_LOCATION_ID}",
        "GHL_BASE_URL": "https://services.leadconnectorhq.com",
        "GHL_INTERNAL_REFRESH_TOKEN": "${GHL_INTERNAL_REFRESH_TOKEN}",
        "GHL_INTERNAL_FIREBASE_KEY": "${GHL_INTERNAL_FIREBASE_KEY}"
      }
    }
  }
}
